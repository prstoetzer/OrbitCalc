10 REM ORBITCALC FOR GW-BASIC
20 REM NEXT-10-PASSES AND 10-DAY EQX TABLES FROM AMSAT ELEMENTS
30 REM SECULAR-J2 MEAN-ELEMENT PROPAGATION. ANGLES IN RADIANS.
40 REM RUNS IN GW-BASIC / BASICA / PC-BASIC. DOUBLE PRECISION.
50 DEFDBL A-H,J-Z
60 PI=4*ATN(1):P2=2*PI:DR=PI/180:RD=180/PI
70 MU=398600.4418#:ER=6378.137#:J2=1.08262668D-3
80 PRINT "=== ORBITCALC (GW-BASIC) ==="
90 GOSUB 2000:REM INPUT ELEMENTS
100 GOSUB 2200:REM INPUT NOW
110 PRINT "1) NEXT 10 PASSES"
120 PRINT "2) 10-DAY REFERENCE ORBIT (EQX)"
130 INPUT "CHOOSE 1 OR 2";CH$
140 GOSUB 2400:REM LOCATION
150 IF CH$="1" THEN GOSUB 3010 ELSE GOSUB 4000
160 END
170 REM
1000 REM ===== SETSAT (USES I9,E9,O9,G9,M9,F9,J9 INPUTS) =====
1010 SI=I9*DR:SE=E9:SO=O9*DR:SG=G9*DR:SM=M9*DR
1020 SN=F9*P2/86400!
1030 SJ=J9
1040 SA=(MU/(SN*SN))^(1/3)
1050 PP=SA*(1-SE*SE)
1060 FF=1.5*J2*(ER/PP)^2*SN
1070 SRD=-FF*COS(SI)
1080 SPD=FF*(2-2.5*SIN(SI)*SIN(SI))
1090 RETURN
1100 REM ===== JD: INPUTS YA,MA,DA,HA,NA,SA2 -> JR =====
1110 IF MA>2 THEN GOTO 1130
1120 YA=YA-1:MA=MA+12
1130 AA=INT(YA/100):BB=2-AA+INT(AA/4)
1140 JR=INT(365.25*(YA+4716))+INT(30.6001*(MA+1))+DA+BB-1524.5
1150 JR=JR+(HA+NA/60+SA2/3600)/24
1160 RETURN
1200 REM ===== GMST(JG) -> GR (RADIANS) =====
1210 TG=(JG-2451545!)/36525!
1220 GG=280.46061837#+360.98564736629#*(JG-2451545!)+.000387933#*TG*TG
1230 GG=GG-360*INT(GG/360)
1240 IF GG<0 THEN GG=GG+360
1250 GR=GG*DR
1260 RETURN
1300 REM ===== KEPLER: INPUTS MK,EK -> EK2 =====
1310 EK2=MK
1320 FOR KK=1 TO 50
1330 DK=(EK2-EK*SIN(EK2)-MK)/(1-EK*COS(EK2))
1340 EK2=EK2-DK
1350 IF ABS(DK)<1D-12 THEN KK=50
1360 NEXT KK
1370 RETURN
1400 REM ===== ATAN2: INPUTS YT,XT -> AT =====
1410 IF XT>0 THEN AT=ATN(YT/XT):RETURN
1420 IF XT<0 AND YT>=0 THEN AT=ATN(YT/XT)+PI:RETURN
1430 IF XT<0 AND YT<0 THEN AT=ATN(YT/XT)-PI:RETURN
1440 IF XT=0 AND YT>0 THEN AT=PI/2:RETURN
1450 IF XT=0 AND YT<0 THEN AT=-PI/2:RETURN
1460 AT=0:RETURN
1500 REM ===== ECI AT JC -> XI,YI,ZI =====
1510 DT=(JC-SJ)*86400!
1520 MM=SM+SN*DT:RN=SO+SRD*DT:AG=SG+SPD*DT
1530 MM=MM-P2*INT(MM/P2)
1540 MK=MM:EK=SE:GOSUB 1300:EE=EK2
1550 XO=SA*(COS(EE)-SE):YO=SA*SQR(1-SE*SE)*SIN(EE)
1560 YT=YO:XT=XO:GOSUB 1400:UU=AT+AG
1570 RR=SQR(XO*XO+YO*YO)
1580 C1=COS(RN):S1=SIN(RN):C2=COS(UU):S2=SIN(UU):C3=COS(SI):S3=SIN(SI)
1590 XI=RR*(C1*C2-S1*S2*C3)
1600 YI=RR*(S1*C2+C1*S2*C3)
1610 ZI=RR*(S2*S3)
1620 RETURN
1700 REM ===== ECEF AT JC -> XE,YE,ZE =====
1710 GOSUB 1500
1720 JG=JC:GOSUB 1200
1730 CG=COS(GR):SG2=SIN(GR)
1740 XE=CG*XI+SG2*YI:YE=-SG2*XI+CG*YI:ZE=ZI
1750 RETURN
1800 REM ===== SUBPOINT AT JC -> BLAT,BLON =====
1810 GOSUB 1700
1820 YT=YE:XT=XE:GOSUB 1400:BLON=AT
1830 YT=ZE:XT=SQR(XE*XE+YE*YE):GOSUB 1400:BLAT=AT
1840 RETURN
1900 REM ===== LOOK AT JC,OLAT,OLON -> EL,AZ =====
1910 GOSUB 1700
1920 CL=COS(OLAT):SL=SIN(OLAT):CO=COS(OLON):SO2=SIN(OLON)
1930 OX=ER*CL*CO:OY=ER*CL*SO2:OZ=ER*SL
1940 VX=XE-OX:VY=YE-OY:VZ=ZE-OZ
1950 SS=SL*CO*VX+SL*SO2*VY-CL*VZ
1960 EE2=-SO2*VX+CO*VY
1970 ZZ=CL*CO*VX+CL*SO2*VY+SL*VZ
1980 RG=SQR(VX*VX+VY*VY+VZ*VZ)
1990 EL=ATN((ZZ/RG)/SQR(1-(ZZ/RG)*(ZZ/RG)))
1992 YT=EE2:XT=-SS:GOSUB 1400:AZ=AT
1994 IF AZ<0 THEN AZ=AZ+P2
1996 RETURN
2000 REM ===== INPUT ELEMENTS =====
2010 PRINT "ENTER ELEMENTS (AMSAT BULLETIN):"
2020 INPUT "  INCLINATION";I9
2030 INPUT "  ECCENTRICITY";E9
2040 INPUT "  RA OF ASC NODE";O9
2050 INPUT "  ARG OF PERICENTER";G9
2060 INPUT "  MEAN ANOMALY";M9
2070 INPUT "  MEAN MOTION";F9
2080 PRINT "  EPOCH UTC:"
2090 INPUT "    YEAR";YA
2100 INPUT "    MONTH";MA
2110 INPUT "    DAY";DA
2120 INPUT "    HOUR";HA
2130 INPUT "    MIN";NA
2140 INPUT "    SEC";SA2
2150 GOSUB 1100:J9=JR
2160 GOSUB 1000
2170 RETURN
2200 REM ===== INPUT NOW =====
2210 PRINT "CURRENT UTC DATE/TIME:"
2220 INPUT "  YEAR";YA
2230 INPUT "  MONTH";MA
2240 INPUT "  DAY";DA
2250 INPUT "  HOUR";HA
2260 INPUT "  MIN";NA
2270 SA2=0
2280 GOSUB 1100:NJ=JR
2290 RETURN
2400 REM ===== LOCATION =====
2410 INPUT "MAIDENHEAD GRID (Y/N)";Q$
2420 IF Q$="Y" OR Q$="y" THEN GOSUB 2500 ELSE GOSUB 2600
2430 RETURN
2500 INPUT "  GRID";GD$
2510 GOSUB 2700
2520 RETURN
2600 INPUT "  LATITUDE (+N)";LA
2610 INPUT "  LONGITUDE (+E)";LO
2620 OLAT=LA*DR:OLON=LO*DR
2630 RETURN
2700 REM ===== MAIDEN GD$ -> OLAT,OLON =====
2710 G$=GD$
2720 LO=(ASC(MID$(G$,1,1))-65)*20-180
2730 LA=(ASC(MID$(G$,2,1))-65)*10-90
2740 LO=LO+(ASC(MID$(G$,3,1))-48)*2
2750 LA=LA+(ASC(MID$(G$,4,1))-48)
2760 IF LEN(G$)>=6 THEN GOTO 2790
2770 LO=LO+1:LA=LA+.5
2780 GOTO 2810
2790 LO=LO+(ASC(MID$(G$,5,1))-65)/12+1/24
2800 LA=LA+(ASC(MID$(G$,6,1))-65)/24+1/48
2810 OLAT=LA*DR:OLON=LO*DR
2820 RETURN
2900 REM ===== CAL JC -> CY,CO,CD,CH,CN,CS =====
2910 JZ=JC+.5:ZZ2=INT(JZ):FZ=JZ-ZZ2
2920 IF ZZ2<2299161! THEN AC=ZZ2:GOTO 2950
2930 AL=INT((ZZ2-1867216.25#)/36524.25#)
2940 AC=ZZ2+1+AL-INT(AL/4)
2950 BC=AC+1524:CC=INT((BC-122.1)/365.25)
2960 DC=INT(365.25*CC):EC=INT((BC-DC)/30.6001)
2970 DY=BC-DC-INT(30.6001*EC)+FZ
2980 IF EC<14 THEN CO=EC-1 ELSE CO=EC-13
2990 IF CO>2 THEN CY=CC-4716 ELSE CY=CC-4715
3000 REM (FALLTHROUGH GUARD)
3001 CD=INT(DY):SC=(DY-CD)*86400!
3002 CH=INT(SC/3600):SC=SC-CH*3600
3003 CN=INT(SC/60):CS=SC-CN*60
3004 RETURN
3010 REM ===== PASSES =====
3020 ST=30/86400!:JC=NJ:JE=NJ+12:IP=0:NP=0
3030 PRINT "DATE  AOS   LOS   EL AZA/AZT/AZL"
3040 JC=JC
3050 IF JC>=JE THEN RETURN
3060 IF NP>=10 THEN RETURN
3070 GOSUB 1900
3080 IF EL>=0 AND IP=0 THEN GOSUB 3200
3090 IF IP=1 THEN GOSUB 3300
3100 JC=JC+ST
3110 GOTO 3050
3200 REM AOS REFINE
3210 A0=JC-ST:A1=JC
3220 FOR KP=1 TO 25
3230 MJ=(A0+A1)/2:JC2=JC:JC=MJ:GOSUB 1900:JC=JC2
3240 IF EL>=0 THEN A1=MJ ELSE A0=MJ
3250 NEXT KP
3260 AO=A1:JC2=JC:JC=AO:GOSUB 1900:JC=JC2:ZA=AZ
3270 IP=1:ME=-9
3280 RETURN
3300 REM MID/LOS/TCA
3310 GOSUB 1900
3320 IF EL>ME THEN ME=EL:TC=JC
3330 IF EL>=0 THEN RETURN
3340 A0=JC-ST:A1=JC
3350 FOR KP=1 TO 25
3360 MJ=(A0+A1)/2:JC2=JC:JC=MJ:GOSUB 1900:JC=JC2
3370 IF EL>=0 THEN A0=MJ ELSE A1=MJ
3380 NEXT KP
3390 LS=A0:JC2=JC:JC=LS:GOSUB 1900:JC=JC2:ZL=AZ
3400 T0=TC-ST:T1=TC+ST
3410 FOR KP=1 TO 40
3420 ML=T0+(T1-T0)/3:MR=T1-(T1-T0)/3
3430 JC2=JC:JC=ML:GOSUB 1900:QL=EL:JC=MR:GOSUB 1900:QR=EL:JC=JC2
3440 IF QL<QR THEN T0=ML ELSE T1=MR
3450 NEXT KP
3460 TC=(T0+T1)/2:JC2=JC:JC=TC:GOSUB 1900:JC=JC2:ME=EL:ZT=AZ
3470 JC2=JC:JC=AO:GOSUB 2900:JC=JC2
3480 PRINT RIGHT$("0"+MID$(STR$(CD),2),2);"/";RIGHT$("0"+MID$(STR$(CO),2),2);" ";
3490 PRINT RIGHT$("0"+MID$(STR$(CH),2),2);":";RIGHT$("0"+MID$(STR$(CN),2),2);"-";
3500 JC2=JC:JC=LS:GOSUB 2900:JC=JC2
3510 PRINT RIGHT$("0"+MID$(STR$(CH),2),2);":";RIGHT$("0"+MID$(STR$(CN),2),2);" ";
3520 PRINT MID$(STR$(INT(ME*RD+.5)),2);" ";
3530 PRINT MID$(STR$(INT(ZA*RD+.5)),2);"/";MID$(STR$(INT(ZT*RD+.5)),2);"/";MID$(STR$(INT(ZL*RD+.5)),2)
3540 IP=0:NP=NP+1
3550 RETURN
4000 REM ===== EQX TABLE =====
4010 IF OLAT<0 THEN SOU=1 ELSE SOU=0
4020 IF SOU=1 THEN AS=0 ELSE AS=1
4030 JC=NJ:GOSUB 2900
4040 YA=CY:MA=CO:DA=CD:HA=0:NA=0:SA2=0:GOSUB 1100:D0=JR
4050 IF SOU=1 THEN PRINT "FIRST DESCENDING-NODE EQX/DAY" ELSE PRINT "FIRST ASCENDING-NODE EQX/DAY"
4060 PRINT "DATE  UTC   EQX-LON"
4070 FOR KD=0 TO 9
4080 DS=D0+KD
4090 GOSUB 4200
4100 IF EQ=1 THEN GOSUB 4400
4110 NEXT KD
4120 RETURN
4200 REM FIND EQX IN DAY DS (NODE AS) -> EJ,ELO,EQ
4210 ST=60/86400!:JC=DS:JE=DS+1:PL=999:EQ=0
4220 IF JC>=JE THEN RETURN
4230 IF EQ=1 THEN RETURN
4240 GOSUB 1800
4250 IF PL=999 THEN PL=BLAT:JC=JC+ST:GOTO 4220
4260 CR=0
4270 IF AS=1 AND PL<0 AND BLAT>=0 THEN CR=1
4280 IF AS=0 AND PL>0 AND BLAT<=0 THEN CR=1
4290 IF CR=0 THEN PL=BLAT:JC=JC+ST:GOTO 4220
4300 A0=JC-ST:A1=JC
4310 FOR KP=1 TO 40
4320 MJ=(A0+A1)/2:JC2=JC:JC=MJ:GOSUB 1800:JC=JC2
4330 IF (BLAT>=0)=(AS=1) THEN A1=MJ ELSE A0=MJ
4340 NEXT KP
4350 MJ=(A0+A1)/2:JC2=JC:JC=MJ:GOSUB 1800:JC=JC2
4360 EJ=MJ:ELO=BLON:EQ=1
4370 RETURN
4400 REM PRINT EQX ROW
4410 JC=EJ:GOSUB 2900
4420 PRINT RIGHT$("0"+MID$(STR$(CD),2),2);"/";RIGHT$("0"+MID$(STR$(CO),2),2);" ";
4430 PRINT RIGHT$("0"+MID$(STR$(CH),2),2);":";RIGHT$("0"+MID$(STR$(CN),2),2);" ";
4440 LD=ELO*RD
4450 IF LD>=0 THEN EW$="E" ELSE EW$="W":LD=-LD
4460 WH=INT(LD):FR=INT((LD-WH)*10+.5)
4470 IF FR>=10 THEN WH=WH+1:FR=0
4480 PRINT MID$(STR$(WH),2);".";MID$(STR$(FR),2);" ";EW$
4490 RETURN
