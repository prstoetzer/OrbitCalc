10 REM OSCARLOCATOR FOR GW-BASIC
20 REM EQX CROSSINGS FOR ONE UTC DAY FROM ONE EQX + PERIOD + ADVANCE
30 REM LONGITUDE +E / -W. INPUT ACCEPTS TRAILING E/W OR A SIGN.
40 DEFDBL A-H,J-Z
50 PRINT "=== OSCARLOCATOR (GW-BASIC) ==="
60 INPUT "EQX LON (E.G. 111.6W OR -111.6)";L$
70 GOSUB 1000:L0=PL
80 INPUT "NODE 1=ASC 2=DESC";ND
90 INPUT "MONTH";MO
100 INPUT "DAY";DY
110 INPUT "EQX HOUR";HH
120 INPUT "EQX MIN";MN
130 INPUT "PERIOD (MIN)";PE
140 INPUT "ADVANCE/ORBIT (DEG W)";AV
150 IF ND=1 THEN NO$="ASC" ELSE NO$="DESC"
160 T0=HH*60+MN
170 KK=INT(T0/PE)
180 TT=T0-KK*PE
190 LN=L0+KK*AV:GOSUB 1100:LN=WL
200 PRINT RIGHT$("0"+MID$(STR$(MO),2),2);"/";RIGHT$("0"+MID$(STR$(DY),2),2);"  ";NO$
210 PRINT "ORB UTC    EQX-LON"
220 NN=0
230 HX=INT(TT/60):MX=INT(TT-HX*60)
240 WW=LN:GOSUB 1100:LN=WL
250 PRINT RIGHT$("0"+MID$(STR$(NN),2),2);"  ";RIGHT$("0"+MID$(STR$(HX),2),2);":";RIGHT$("0"+MID$(STR$(MX),2),2);"  ";
260 LD=LN:GOSUB 1200
270 TT=TT+PE
280 LN=LN-AV:WW=LN:GOSUB 1100:LN=WL
290 NN=NN+1
300 IF TT<1440 THEN GOTO 230
310 END
1000 REM ===== PARSE LON L$ -> PL =====
1010 C$=RIGHT$(L$,1):SG=1:B$=L$
1020 IF C$="W" OR C$="w" THEN SG=-1:B$=LEFT$(L$,LEN(L$)-1)
1030 IF C$="E" OR C$="e" THEN B$=LEFT$(L$,LEN(L$)-1)
1040 PL=SG*VAL(B$)
1050 RETURN
1100 REM ===== WRAP WW -> WL =====
1110 WL=WW
1120 IF WL>180 THEN WL=WL-360:GOTO 1120
1130 IF WL<=-180 THEN WL=WL+360:GOTO 1130
1140 RETURN
1200 REM ===== PRINT LON LD WITH E/W =====
1210 IF LD>=0 THEN EW$="E" ELSE EW$="W":LD=-LD
1220 WH=INT(LD):FR=INT((LD-WH)*10+.5)
1230 IF FR>=10 THEN WH=WH+1:FR=0
1240 PRINT MID$(STR$(WH),2);".";MID$(STR$(FR),2);" ";EW$
1250 RETURN
