10 REM SATFREQ FOR GW-BASIC - FREQUENCY & MODE REFERENCE CARD
20 REM SNAPSHOT 2026-06; VERIFY AGAINST CURRENT AMSAT LIST BEFORE A PASS.
30 DEFINT I-N
40 NS=12
50 DIM NM$(NS),UP(NS),DN(NS),MD$(NS),IV(NS),TN$(NS),NT$(NS)
60 FOR I=1 TO NS
70 READ NM$(I),UP(I),DN(I),MD$(I),IV(I),TN$(I),NT$(I)
80 NEXT I
90 PRINT "=== SATFREQ (GW-BASIC) ==="
100 PRINT "SNAPSHOT 2026-06; VERIFY!"
110 PRINT "NAME/PART, L=LIST, Q=QUIT"
120 INPUT "> ";Q$
130 GOSUB 500:Q$=U$
140 IF Q$="Q" THEN END
150 IF Q$="L" THEN FOR I=1 TO NS:PRINT "  ";NM$(I):NEXT I:GOTO 120
160 IF Q$="" THEN 120
170 HT=0
180 FOR I=1 TO NS
190 G$=NM$(I):GOSUB 540
200 IF INSTR(U$,Q$)>0 THEN GOSUB 300:HT=1
210 NEXT I
220 IF HT=0 THEN PRINT "NO MATCH. L=LIST"
230 GOTO 120
300 REM ===== SHOW(I) =====
310 PRINT NM$(I)
320 PRINT "  UP   ";UP(I);"MHZ"
330 PRINT "  DOWN ";DN(I);"MHZ"
340 IF IV(I)=1 THEN PRINT "  MODE ";MD$(I);" INV" ELSE PRINT "  MODE ";MD$(I);" NON-INV"
350 IF TN$(I)<>"" THEN PRINT "  TONE ";TN$(I);"HZ"
360 IF NT$(I)<>"" THEN PRINT "  NOTE ";NT$(I)
370 RETURN
500 REM ===== UPPER Q$ -> U$ =====
510 G$=Q$
540 U$="":FOR J=1 TO LEN(G$):C=ASC(MID$(G$,J,1)):IF C>=97 AND C<=122 THEN C=C-32
550 U$=U$+CHR$(C):NEXT J
560 RETURN
