10 REM DECAY FOR GW-BASIC - ELEMENT FRESHNESS & DECAY FLAG
20 DEFDBL A-H,J-Z
30 PI=4*ATN(1):P2=2*PI
40 MU=398600.4418#:ER=6378.137#
50 PRINT "=== DECAY (GW-BASIC) ==="
60 INPUT "MM REV/DAY";MM
70 INPUT "ECC";EC
80 PRINT "EPOCH UTC:"
90 INPUT "  YR";YA:INPUT "  MO";MA:INPUT "  DY";DA:INPUT "  HR";HA:INPUT "  MI";NA
100 SA2=0:GOSUB 1100:EP=JR
110 PRINT "NOW UTC:"
120 INPUT "  YR";YA:INPUT "  MO";MA:INPUT "  DY";DA:INPUT "  HR";HA:INPUT "  MI";NA
130 SA2=0:GOSUB 1100:NJ=JR
140 AG=NJ-EP
150 N=MM*P2/86400!
160 A=(MU/(N*N))^(1/3)
170 AP=A*(1-EC)-ER
180 AA=A*(1+EC)-ER
190 PRINT "AGE";INT(AG*100+.5)/100;"DAYS"
200 IF AG<0 THEN PRINT "! NOW BEFORE EPOCH"
210 IF AG>14 THEN PRINT "! VERY STALE >14D"
220 IF AG>5 AND AG<=14 THEN PRINT "! STALE >5D"
230 IF AG>=0 AND AG<=5 THEN PRINT "FRESH ENOUGH"
240 PRINT "MEAN ALT";INT(A-ER+.5);"KM"
250 PRINT "PERI";INT(AP+.5);"APO";INT(AA+.5);"KM"
260 IF AP<200 THEN PRINT "! RAPID DECAY-REFRESH DAILY"
270 IF AP>=200 AND AP<350 THEN PRINT "! LOW PERI-REFRESH 1-2D"
280 END
1100 REM ===== JD: INPUTS YA,MA,DA,HA,NA,SA2 -> JR =====
1110 YY=YA:MM2=MA
1120 IF MM2<=2 THEN YY=YY-1:MM2=MM2+12
1130 AC=INT(YY/100):BC=2-AC+INT(AC/4)
1140 JR=INT(365.25*(YY+4716))+INT(30.6001*(MM2+1))+DA+BC-1524.5
1150 JR=JR+(HA+NA/60+SA2/3600)/24
1160 RETURN
