10 REM SATTRACK FOR GW-BASIC - GRAPHICAL SATELLITE TRACKER
20 REM EQUIRECTANGULAR WORLD MAP: GRATICULE, SUB-SATELLITE POINT,
30 REM FOOTPRINT CIRCLE, OBSERVER QTH, LIVE AZ/EL/RANGE PANEL.
40 REM SINGLE-SHOT DRAW; PRESS A KEY TO STEP THE CLOCK FORWARD.
50 REM SCREEN 2 (640X200 CGA) - RUNS IN GW-BASIC/BASICA/PC-BASIC.
60 DEFDBL A-H,J-Z
70 PI=4*ATN(1):P2=2*PI:DR=PI/180:RD=180/PI
80 MU=398600.4418#:ER=6378.137#:J2=1.08262668D-3
85 DEF FNAS(X)=ATN(X/SQR(1-X*X+1D-18))
86 DEF FNAC(X)=PI/2-ATN(X/SQR(1-X*X+1D-18))
90 REM MAP RECT IN SCREEN PIXELS (640X200)
100 MX=8:MY=24:MW=624:MH=150
110 PRINT "=== SATTRACK (GW-BASIC) ==="
120 INPUT "GRID";GD$:GOSUB 2700:OLAT=OLAT:OLON=OLON
130 INPUT "INC";I9
140 INPUT "ECC";E9
150 INPUT "RAAN";O9
160 INPUT "ARGP";G9
170 INPUT "MA";M9
180 INPUT "MM";F9
190 PRINT "EPOCH UTC:"
200 INPUT "  YR";YA:INPUT "  MO";MA:INPUT "  DY";DA:INPUT "  HR";HA:INPUT "  MI";NA:INPUT "  SC";SA2
210 GOSUB 1100:J9=JR:GOSUB 1000
220 PRINT "NOW UTC:"
230 INPUT "  YR";YA:INPUT "  MO";MA:INPUT "  DY";DA:INPUT "  HR";HA:INPUT "  MI";NA:SA2=0
240 GOSUB 1100:TJ=JR
250 INPUT "STEP SEC";ST:IF ST<=0 THEN ST=60
260 REM ===== MAIN LOOP =====
270 GOSUB 5000:REM DRAW FRAME
280 K$=INPUT$(1)
290 TJ=TJ+ST/86400!
300 GOTO 270
310 END
320 REM
1000 REM ===== SETSAT (USES I9,E9,O9,G9,M9,F9,J9 INPUTS) =====
1010 SI=I9*DR:SE=E9:SO=O9*DR:SG=G9*DR:SM=M9*DR
1020 SN=F9*P2/86400!
1030 SJ=J9
1040 SA=(MU/(SN*SN))^(1/3)
1050 PP=SA*(1-SE*SE)
1060 FF=1.5*J2*(ER/PP)^2*SN
1070 SRD=-FF*COS(SI)
1080 SPD=FF*(2-2.5*SIN(SI)*SIN(SI))
1090 RETURN
1100 REM ===== JD: INPUTS YA,MA,DA,HA,NA,SA2 -> JR =====
1110 IF MA>2 THEN GOTO 1130
1120 YA=YA-1:MA=MA+12
1130 AA=INT(YA/100):BB=2-AA+INT(AA/4)
1140 JR=INT(365.25*(YA+4716))+INT(30.6001*(MA+1))+DA+BB-1524.5
1150 JR=JR+(HA+NA/60+SA2/3600)/24
1160 RETURN
1200 REM ===== GMST(JG) -> GR (RADIANS) =====
1210 TG=(JG-2451545!)/36525!
1220 GG=280.46061837#+360.98564736629#*(JG-2451545!)+.000387933#*TG*TG
1230 GG=GG-360*INT(GG/360)
1240 IF GG<0 THEN GG=GG+360
1250 GR=GG*DR
1260 RETURN
1300 REM ===== KEPLER: INPUTS MK,EK -> EK2 =====
1310 EK2=MK
1320 FOR KK%=1 TO 50
1330 DK=(EK2-EK*SIN(EK2)-MK)/(1-EK*COS(EK2))
1340 EK2=EK2-DK
1350 IF ABS(DK)<1D-12 THEN KK%=50
1360 NEXT KK%
1370 RETURN
1400 REM ===== ATAN2: INPUTS YT,XT -> AT =====
1410 IF XT>0 THEN AT=ATN(YT/XT):RETURN
1420 IF XT<0 AND YT>=0 THEN AT=ATN(YT/XT)+PI:RETURN
1430 IF XT<0 AND YT<0 THEN AT=ATN(YT/XT)-PI:RETURN
1440 IF XT=0 AND YT>0 THEN AT=PI/2:RETURN
1450 IF XT=0 AND YT<0 THEN AT=-PI/2:RETURN
1460 AT=0:RETURN
1500 REM ===== ECI AT JC -> XI,YI,ZI =====
1510 DT=(JC-SJ)*86400!
1520 MM=SM+SN*DT:RN=SO+SRD*DT:AG=SG+SPD*DT
1530 MM=MM-P2*INT(MM/P2)
1540 MK=MM:EK=SE:GOSUB 1300:EE=EK2
1550 XO=SA*(COS(EE)-SE):YO=SA*SQR(1-SE*SE)*SIN(EE)
1560 YT=YO:XT=XO:GOSUB 1400:UU=AT+AG
1570 RR=SQR(XO*XO+YO*YO)
1580 C1=COS(RN):S1=SIN(RN):C2=COS(UU):S2=SIN(UU):C3=COS(SI):S3=SIN(SI)
1590 XI=RR*(C1*C2-S1*S2*C3)
1600 YI=RR*(S1*C2+C1*S2*C3)
1610 ZI=RR*(S2*S3)
1620 RETURN
1700 REM ===== ECEF AT JC -> XE,YE,ZE =====
1710 GOSUB 1500
1720 JG=JC:GOSUB 1200
1730 CG=COS(GR):SG2=SIN(GR)
1740 XE=CG*XI+SG2*YI:YE=-SG2*XI+CG*YI:ZE=ZI
1750 RETURN
1800 REM ===== SUBPOINT AT JC -> BLAT,BLON =====
1810 GOSUB 1700
1820 YT=YE:XT=XE:GOSUB 1400:BLON=AT
1830 YT=ZE:XT=SQR(XE*XE+YE*YE):GOSUB 1400:BLAT=AT
1840 RETURN
1900 REM ===== LOOK AT JC,OLAT,OLON -> EL,AZ =====
1910 GOSUB 1700
1920 CL=COS(OLAT):SL=SIN(OLAT):CO=COS(OLON):SO2=SIN(OLON)
1930 OX=ER*CL*CO:OY=ER*CL*SO2:OZ=ER*SL
1940 VX=XE-OX:VY=YE-OY:VZ=ZE-OZ
1950 SS=SL*CO*VX+SL*SO2*VY-CL*VZ
1960 EE2=-SO2*VX+CO*VY
1970 ZZ=CL*CO*VX+CL*SO2*VY+SL*VZ
1980 RG=SQR(VX*VX+VY*VY+VZ*VZ)
1990 EL=ATN((ZZ/RG)/SQR(1-(ZZ/RG)*(ZZ/RG)))
1992 YT=EE2:XT=-SS:GOSUB 1400:AZ=AT
1994 IF AZ<0 THEN AZ=AZ+P2
1996 RETURN
2000 REM ===== INPUT ELEMENTS =====
2010 PRINT "ENTER ELEMENTS (AMSAT BULLETIN):"
2020 INPUT "  INCLINATION";I9
2030 INPUT "  ECCENTRICITY";E9
2040 INPUT "  RA OF ASC NODE";O9
2050 INPUT "  ARG OF PERICENTER";G9
2060 INPUT "  MEAN ANOMALY";M9
2070 INPUT "  MEAN MOTION";F9
2080 PRINT "  EPOCH UTC:"
2090 INPUT "    YEAR";YA
2100 INPUT "    MONTH";MA
2110 INPUT "    DAY";DA
2120 INPUT "    HOUR";HA
2130 INPUT "    MIN";NA
2140 INPUT "    SEC";SA2
2150 GOSUB 1100:J9=JR
2160 GOSUB 1000
2170 RETURN
2200 REM ===== INPUT NOW =====
2210 PRINT "CURRENT UTC DATE/TIME:"
2220 INPUT "  YEAR";YA
2230 INPUT "  MONTH";MA
2240 INPUT "  DAY";DA
2250 INPUT "  HOUR";HA
2260 INPUT "  MIN";NA
2270 SA2=0
2280 GOSUB 1100:NJ=JR
2290 RETURN
2400 REM ===== LOCATION =====
2410 INPUT "MAIDENHEAD GRID (Y/N)";Q$
2420 IF Q$="Y" OR Q$="y" THEN GOSUB 2500 ELSE GOSUB 2600
2430 RETURN
2500 INPUT "  GRID";GD$
2510 GOSUB 2700
2520 RETURN
2600 INPUT "  LATITUDE (+N)";LA
2610 INPUT "  LONGITUDE (+E)";LO
2620 OLAT=LA*DR:OLON=LO*DR
2630 RETURN
2700 REM ===== MAIDEN GD$ -> OLAT,OLON =====
2710 G$=GD$
2720 LO=(ASC(MID$(G$,1,1))-65)*20-180
2730 LA=(ASC(MID$(G$,2,1))-65)*10-90
2740 LO=LO+(ASC(MID$(G$,3,1))-48)*2
2750 LA=LA+(ASC(MID$(G$,4,1))-48)
2760 IF LEN(G$)>=6 THEN GOTO 2790
2770 LO=LO+1:LA=LA+.5
2780 GOTO 2810
2790 LO=LO+(ASC(MID$(G$,5,1))-65)/12+1/24
2800 LA=LA+(ASC(MID$(G$,6,1))-65)/24+1/48
2810 OLAT=LA*DR:OLON=LO*DR
2820 RETURN
2900 REM ===== CAL JC -> CY,CO,CD,CH,CN,CS =====
2910 JZ=JC+.5:ZZ2=INT(JZ):FZ=JZ-ZZ2
2920 IF ZZ2<2299161! THEN AC=ZZ2:GOTO 2950
2930 AL=INT((ZZ2-1867216.25#)/36524.25#)
2940 AC=ZZ2+1+AL-INT(AL/4)
2950 BC=AC+1524:CC=INT((BC-122.1)/365.25)
2960 DC=INT(365.25*CC):EC=INT((BC-DC)/30.6001)
2970 DY=BC-DC-INT(30.6001*EC)+FZ
2980 IF EC<14 THEN CO=EC-1 ELSE CO=EC-13
2990 IF CO>2 THEN CY=CC-4716 ELSE CY=CC-4715
3000 REM (FALLTHROUGH GUARD)
3001 CD=INT(DY):SC=(DY-CD)*86400!
3002 CH=INT(SC/3600):SC=SC-CH*3600
3003 CN=INT(SC/60):CS=SC-CN*60
3004 RETURN
5000 REM ===== DRAW FRAME =====
5010 SCREEN 2:CLS
5020 GOSUB 5100:REM GRATICULE
5025 GOSUB 5250:REM COASTLINE
5030 GOSUB 5300:REM OBSERVER
5040 GOSUB 5400:REM SATELLITE+FOOTPRINT
5050 GOSUB 5700:REM PANEL
5060 RETURN
5100 REM ===== GRATICULE =====
5110 LINE (MX,MY)-(MX+MW,MY+MH),1,B
5120 FOR LO%=-180 TO 180 STEP 30
5130 PX=MX+(LO%+180)/360*MW
5140 LINE (PX,MY)-(PX,MY+MH),1
5150 NEXT LO%
5160 FOR LA%=-90 TO 90 STEP 30
5170 PY=MY+(90-LA%)/180*MH
5180 LINE (MX,PY)-(MX+MW,PY),1
5190 NEXT LA%
5200 PY=MY+MH/2:LINE (MX,PY)-(MX+MW,PY),1
5210 RETURN
5250 REM ===== COASTLINE =====
5252 RESTORE 6000
5254 READ NW
5256 IF NW=0 THEN RETURN
5258 LPX2=-999
5260 FOR KC%=1 TO NW
5262 READ CLO,CLA
5264 CPX=MX+(CLO+180)/360*MW
5266 CPY=MY+(90-CLA)/180*MH
5268 IF KC=1 THEN PSET (CPX,CPY),1:GOTO 5274
5270 IF ABS(CPX-LPX2)<MW/2 THEN LINE -(CPX,CPY),1 ELSE PSET (CPX,CPY),1
5274 LPX2=CPX
5276 NEXT KC%
5278 GOTO 5254
5300 REM ===== OBSERVER =====
5310 OA=OLAT*RD:OO=OLON*RD
5320 PX=MX+(OO+180)/360*MW
5330 PY=MY+(90-OA)/180*MH
5340 LINE (PX-5,PY)-(PX+5,PY),1
5350 LINE (PX,PY-5)-(PX,PY+5),1
5360 RETURN
5400 REM ===== SATELLITE + FOOTPRINT =====
5410 JC=TJ:GOSUB 1800:REM BLAT,BLON RAD
5420 SLA=BLAT*RD:SLO=BLON*RD
5430 JC=TJ:GOSUB 1500:RR=SQR(XI*XI+YI*YI+ZI*ZI)
5440 RHO=RD*FNAC(ER/RR)
5450 SX=MX+(SLO+180)/360*MW
5460 SY=MY+(90-SLA)/180*MH
5470 REM FOOTPRINT BOUNDARY
5480 LPX=-999
5490 FOR KB%=0 TO 72
5500 BR=KB%*5*DR
5510 GOSUB 5900:REM FOOTPRINT POINT -> FLA,FLO
5520 FX=MX+(FLO+180)/360*MW
5530 FY=MY+(90-FLA)/180*MH
5540 IF KB%=0 THEN PSET (FX,FY),1:GOTO 5570
5550 IF ABS(FX-LPX)<MW/2 THEN LINE -(FX,FY),1 ELSE PSET (FX,FY),1
5570 LPX=FX
5580 NEXT KB%
5590 LINE (SX-5,SY)-(SX+5,SY),1
5600 LINE (SX,SY-5)-(SX,SY+5),1
5610 LINE (SX-4,SY-4)-(SX+4,SY-4),1
5620 LINE -(SX+4,SY+4),1:LINE -(SX-4,SY+4),1:LINE -(SX-4,SY-4),1
5630 RETURN
5700 REM ===== PANEL =====
5710 JC=TJ:OLAT=OLAT:OLON=OLON:GOSUB 1900:REM EL,AZ,RG
5720 JC=TJ:GOSUB 2900:REM CAL -> CH,CN
5730 LOCATE 1,1
5740 PRINT USING "##:##Z ";CH;CN;
5750 PRINT "LAT";INT(SLA*10+.5)/10;"LON";INT(SLO*10+.5)/10
5760 LOCATE 24,1
5770 IF EL>=0 THEN PRINT "AZ";INT(AZ*RD+.5);" EL";INT(EL*RD+.5);" RNG";INT(RG);"KM"; ELSE PRINT "BELOW HORIZON";
5780 RETURN
5900 REM ===== FOOTPRINT POINT: SLA,SLO,RHO,BR -> FLA,FLO =====
5910 L0=SLA*DR:B0=SLO*DR:R0=RHO*DR
5920 FA=FNAS(SIN(L0)*COS(R0)+COS(L0)*SIN(R0)*COS(BR))
5930 YT=SIN(BR)*SIN(R0)*COS(L0):XT=COS(R0)-SIN(L0)*SIN(FA):GOSUB 1400
5940 FLA=FA*RD:FLO=B0*RD+AT*RD
5950 IF FLO>180 THEN FLO=FLO-360
5960 IF FLO<-180 THEN FLO=FLO+360
5970 RETURN
